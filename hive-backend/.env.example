# =============================================================================
# Hive Backend — API Keys
# Rename this file to .env and add your real keys below.
# DO NOT commit the real .env to version control!
# =============================================================================

# OpenAI API Key (required if provider='openai')
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key (required if provider='anthropic')
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here

# Google Gemini API Key (required if provider='google')
GEMINI_API_KEY=your-gemini-key-here

# Groq API Key (required if provider='groq')
GROQ_API_KEY=gsk_your_groq_key_here
